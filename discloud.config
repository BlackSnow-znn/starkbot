# ============================================================
# ⚙️ DISCLOUD CONFIG — STARK STORE BOT
# Arquivo de configuração para hospedagem na Discloud
# Documentação: https://docs.discloudbot.com
# ============================================================

# Nome do seu app na Discloud (pode ser qualquer nome)
ID=stark-store-bot

# Tipo do app: bot (para bots Discord)
TYPE=bot

# Arquivo principal que será executado
MAIN=index.js

# Versão do Node.js (mínimo 18 para discord.js v14)
# Versões disponíveis: 18, 20, 22
RAM=100

# Versão do runtime
VERSION=18

# Permite que o bot reinicie automaticamente em caso de crash
AUTO_RESTART=true
