# ============================================================
# 🔐 VARIÁVEIS DE AMBIENTE — STARK STORE BOT
# Copie este arquivo para .env e preencha com seus valores
# NUNCA envie o arquivo .env para o GitHub!
# ============================================================

# ─────────────────────────────────────────────────────────────
# 🔑 CREDENCIAIS DO BOT
# Encontradas no Discord Developer Portal: https://discord.com/developers/applications
# ─────────────────────────────────────────────────────────────

# Token do bot (em Bot > Token > Reset Token)
TOKEN=SEU_TOKEN_AQUI

# ID do bot (em OAuth2 > Client ID)
CLIENT_ID=ID_DO_BOT_AQUI

# ─────────────────────────────────────────────────────────────
# 🏠 CONFIGURAÇÕES DO SERVIDOR
# Para obter IDs: Ative Modo Desenvolvedor nas Configurações do Discord
# Configurações > Avançado > Modo Desenvolvedor ✅
# Depois clique com botão direito no item > Copiar ID
# ─────────────────────────────────────────────────────────────

# ID do servidor (Guild) — clique direito no ícone do servidor
GUILD_ID=ID_DO_SERVIDOR_AQUI

# ID do cargo de Staff — clique direito no cargo em Configurações > Cargos
STAFF_ROLE_ID=ID_DO_CARGO_STAFF_AQUI

# ID do canal de logs — clique direito no canal de texto
LOG_CHANNEL_ID=ID_DO_CANAL_LOGS_AQUI

# ─────────────────────────────────────────────────────────────
# 📂 IDs DAS CATEGORIAS DOS TICKETS
# Clique direito na categoria (pasta) no servidor > Copiar ID
# Crie uma categoria diferente para cada tipo de ticket
# ─────────────────────────────────────────────────────────────

# Categoria para tickets de Suporte
CAT_SUPORTE=ID_CATEGORIA_SUPORTE_AQUI

# Categoria para tickets de Dúvidas
CAT_DUVIDAS=ID_CATEGORIA_DUVIDAS_AQUI

# Categoria para tickets de Denúncia
CAT_DENUNCIA=ID_CATEGORIA_DENUNCIA_AQUI

# Categoria para tickets de Compras
CAT_COMPRAS=ID_CATEGORIA_COMPRAS_AQUI

# Categoria para tickets de Parcerias
CAT_PARCERIAS=ID_CATEGORIA_PARCERIAS_AQUI

# Categoria para tickets de Reset HWID
CAT_HWID=ID_CATEGORIA_HWID_AQUI
